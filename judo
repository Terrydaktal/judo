#!/bin/bash
set -euo pipefail

JUDO_VERSION="0.1.4"

usage() {
  cat <<EOF
judo ${JUDO_VERSION}

judo installs a self-contained application from either an archive, a URL, or a directory by extracting or inspecting it, heuristically selecting the most likely main executable, and then either keeping the source tree in place or copying the application files into /opt/<AppName>. It always creates a per-user desktop launcher in ~/.local/share/applications and a per-user command symlink in ~/.local/bin (lowercased). Archive installs are safe to re-run: each run clears the temporary extraction directory, stages the install under /opt, and replaces any existing /opt/<AppName> with a timestamped backup.

Usage:
  judo [--force] <source-archive-directory-or-url> <AppName>
  judo uninstall <AppName>

Arguments:
  <source-archive-directory-or-url>
              Archive path, directory path, or http(s) URL to install
              (.tar, .tar.gz/.tgz, .tar.bz2/.tbz2, .tar.xz/.txz, .tar.zst/.tzst,
               .pkg.tar.zst, .zip, .deb, .rpm, or a folder containing a project or extracted archive)
  <AppName>   Logical application name used for naming paths and selecting an executable.

Uninstall:
  uninstall   Remove judo-managed integration for <AppName>.
              Deletes:
                ~/.local/share/applications/<appname>.desktop
                ~/.local/bin/<appname>
                ~/.local/share/icons/judo/<appname>.*
              If /opt/<AppName> exists, it is removed too. If the executable points outside /opt,
              judo leaves the original source tree alone.

What it creates (derived from <AppName>):
  Archive install directory:
    /opt/<AppName>

  Directory install:
    Source tree stays where it is; only the desktop file and ~/.local/bin symlink are created/updated.

  Temporary extraction directory:
    /tmp/<AppName>-extract

  Desktop launcher (per-user, lowercased filename):
    ~/.local/share/applications/<appname>.desktop

  Symlink command (per-user, lowercased name):
    ~/.local/bin/<appname>

Executable selection:
  The script scans the extracted files for executables and picks the best candidate using
  name-based heuristics (prefers exact filename matches to <AppName> and case variants,
  then files whose names contain <AppName>; prefers non-hidden paths and bin/ or app/
  directories; de-prioritizes common helper/debug/test/daemon executables).

Install modes (copy source selection):
  Mode A (archive input):
    The archive is extracted, staged under /opt/.<AppName>.staging.<pid>, and then
    atomically moved into /opt/<AppName>.

  Mode B (directory input):
    The source tree is kept in place. judo only creates/replaces the desktop file and
    ~/.local/bin symlink, both pointing at the executable inside the provided directory.

Desktop file behavior:
  If a vendor *.desktop file is found inside the archive, judo will reuse it but overwrite:
    Version, Name, Exec, Icon, Terminal, Type, Categories
  All other vendor keys (e.g. StartupWMClass, MimeType, Actions) are preserved.
  If no vendor desktop file is found, judo generates a minimal desktop file.

Re-run behavior:
  Safe to run multiple times. Archive runs:
    - clear the temp extraction directory
    - stage install under /opt and atomically replace /opt/<AppName>
    - move any previous /opt/<AppName> to /opt/.<AppName>.backup.<timestamp>
  Directory runs:
    - leave the source tree where it is
    - replace the desktop file and ~/.local/bin symlink in place

Notes:
  - The symlink and desktop file names are derived from <AppName> but are lowercased.
  - Ensure ~/.local/bin is on your PATH to run <appname> from the terminal.
  - If generated names already exist, judo asks whether to overwrite, use a new name, or cancel.
    Archive installs include /opt/<AppName>; all installs also check the desktop file,
    ~/.local/bin symlink, and any generated icon under ~/.local/share/icons/judo/<appname>.*.
  - If <source-archive-directory-or-url> starts with http:// or https://, judo downloads it using curl -L first.
  - If <source-archive-directory-or-url> is a directory, judo uses it directly as the source tree.
  - For .deb/.rpm input, judo extracts package payload only, then installs from that tree.
EOF
}

FORCE=0
MODE="install"
while (( $# > 0 )); do
  case "$1" in
    --force)
      FORCE=1
      shift
      ;;
    uninstall)
      MODE="uninstall"
      shift
      break
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -V|--version)
      printf 'judo %s\n' "$JUDO_VERSION"
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      error_line "Unknown option: $1"
      usage
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

SOURCE_INPUT=""
APP_NAME=""
ARCHIVE=""
DOWNLOADED_ARCHIVE=""
DEB_WORK_DIR=""
SOURCE_ROOT=""
SOURCE_IS_DIRECTORY=0

USER_NAME="$(logname)"
USER_HOME="$(eval echo "~${USER_NAME}")"
LOCAL_BIN_DIR="${USER_HOME}/.local/bin"
LOCAL_ICON_DIR="${USER_HOME}/.local/share/icons/judo"
SYSTEM_RM="/bin/rm"

COLOR_ENABLED=0
if [[ -z "${NO_COLOR:-}" && ( -t 0 || -t 1 || -t 2 ) ]]; then
  COLOR_ENABLED=1
fi

if (( COLOR_ENABLED == 1 )); then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_DIM=$'\033[2m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'
  C_MAGENTA=$'\033[35m'
  C_CYAN=$'\033[36m'
else
  C_RESET=""
  C_BOLD=""
  C_DIM=""
  C_RED=""
  C_GREEN=""
  C_YELLOW=""
  C_BLUE=""
  C_MAGENTA=""
  C_CYAN=""
fi

color_wrap() {
  local color="$1"
  shift
  printf '%b%s%b' "$color" "$*" "$C_RESET"
}

status_line() {
  printf '%b%s%b\n' "${C_BOLD}${C_CYAN}" "$*" "$C_RESET"
}

info_line() {
  printf '%b%s%b\n' "$C_CYAN" "$*" "$C_RESET"
}

warn_line() {
  printf '%b%s%b\n' "$C_YELLOW" "$*" "$C_RESET"
}

error_line() {
  printf '%b%s%b\n' "$C_RED" "$*" "$C_RESET" >&2
}

success_line() {
  printf '%b%s%b\n' "$C_GREEN" "$*" "$C_RESET"
}

prompt_text() {
  printf '%b%s%b' "${C_BOLD}${C_BLUE}" "$*" "$C_RESET"
}

refresh_name_paths() {
  INSTALL_DIR="/opt/${APP_NAME}"
  DESKTOP_FILE="${USER_HOME}/.local/share/applications/${APP_NAME,,}.desktop"
  TEMP_DIR="/tmp/${APP_NAME}-extract"
  STAGE_DIR="/opt/.${APP_NAME}.staging.$$"
  BACKUP_DIR="/opt/.${APP_NAME}.backup.$(date +%Y%m%d-%H%M%S)"
  SYMLINK_PATH="${LOCAL_BIN_DIR}/${APP_NAME,,}"
  USER_ICON_STEM="${LOCAL_ICON_DIR}/${APP_NAME,,}"
}

resolve_uninstall_target() {
  if [[ -L "$SYMLINK_PATH" ]]; then
    readlink -f "$SYMLINK_PATH" 2>/dev/null || true
    return
  fi

  if [[ -f "$DESKTOP_FILE" ]]; then
    awk -F= '
      /^Exec=/ {
        exec=$2
        sub(/^"/, "", exec)
        sub(/".*$/, "", exec)
        sub(/[[:space:]].*$/, "", exec)
        print exec
        exit
      }
    ' "$DESKTOP_FILE" 2>/dev/null || true
  fi
}

uninstall_app() {
  local target_path=""
  local icon_ext
  local removed_any=0

  info_line "Uninstalling $APP_NAME..."

  if [[ -e "$DESKTOP_FILE" ]]; then
    info_line "Removing desktop file: $DESKTOP_FILE"
    sudo -u "$USER_NAME" "$SYSTEM_RM" -f "$DESKTOP_FILE"
    removed_any=1
  fi

  if [[ -e "$SYMLINK_PATH" ]]; then
    info_line "Removing launcher: $SYMLINK_PATH"
    sudo -u "$USER_NAME" "$SYSTEM_RM" -f "$SYMLINK_PATH"
    removed_any=1
  fi

  for icon_ext in png svg xpm ico; do
    if [[ -e "${USER_ICON_STEM}.${icon_ext}" ]]; then
      info_line "Removing icon: ${USER_ICON_STEM}.${icon_ext}"
      sudo -u "$USER_NAME" "$SYSTEM_RM" -f "${USER_ICON_STEM}.${icon_ext}"
      removed_any=1
    fi
  done

  target_path="$(resolve_uninstall_target)"
  if [[ -e "$INSTALL_DIR" ]]; then
    info_line "Removing install directory: $INSTALL_DIR"
    sudo rm -rf "$INSTALL_DIR"
    removed_any=1
  elif [[ -n "$target_path" ]]; then
    if [[ "$target_path" == "$INSTALL_DIR" || "$target_path" == "$INSTALL_DIR"/* ]]; then
      info_line "Removing install directory: $INSTALL_DIR"
      sudo rm -rf "$INSTALL_DIR"
      removed_any=1
    else
      info_line "Executable is outside /opt; leaving source tree in place: $target_path"
    fi
  fi

  if (( removed_any == 0 )); then
    warn_line "Nothing to remove for '$APP_NAME'."
    return
  fi

  success_line "=== UNINSTALL COMPLETE ==="
  printf '%b%s%b %s\n' "${C_BOLD}${C_GREEN}" "Desktop file:" "$C_RESET" "$DESKTOP_FILE"
  printf '%b%s%b %s\n' "${C_BOLD}${C_GREEN}" "Symlink:" "$C_RESET" "$SYMLINK_PATH"
  printf '%b%s%b %s.*\n' "${C_BOLD}${C_GREEN}" "Icon stem:" "$C_RESET" "$USER_ICON_STEM"
  printf '%b%s%b %s\n' "${C_BOLD}${C_GREEN}" "Install dir:" "$C_RESET" "$INSTALL_DIR"
}

TMP_DESKTOP="$(mktemp)"

cleanup() {
  "$SYSTEM_RM" -rf "$TEMP_DIR" "/tmp/${APP_NAME}-best-exec" 2>/dev/null || true
  "$SYSTEM_RM" -rf "$DEB_WORK_DIR" 2>/dev/null || true
  "$SYSTEM_RM" -f "$TMP_DESKTOP" 2>/dev/null || true
  "$SYSTEM_RM" -f "$DOWNLOADED_ARCHIVE" 2>/dev/null || true
  sudo rm -rf "$STAGE_DIR" 2>/dev/null || true
}
trap cleanup EXIT

if [[ "$MODE" == "uninstall" ]]; then
  if (( $# != 1 )); then
    usage
    exit 1
  fi
  APP_NAME="$1"
else
  if (( $# != 2 )); then
    usage
    exit 1
  fi
  SOURCE_INPUT="$1"
  APP_NAME="$2"
  ARCHIVE="$SOURCE_INPUT"
fi

find_name_conflicts() {
  NAME_CONFLICTS=()
  local icon_ext

  if (( SOURCE_IS_DIRECTORY == 0 )) && [[ -e "$INSTALL_DIR" ]]; then
    NAME_CONFLICTS+=("Install path exists: $INSTALL_DIR")
  fi
  if [[ -e "$DESKTOP_FILE" ]]; then
    NAME_CONFLICTS+=("Desktop file exists: $DESKTOP_FILE")
  fi
  if [[ -e "$SYMLINK_PATH" ]]; then
    if [[ -L "$SYMLINK_PATH" ]]; then
      NAME_CONFLICTS+=("Local bin symlink exists: $SYMLINK_PATH")
    else
      NAME_CONFLICTS+=("Local bin entry exists and is not a symlink: $SYMLINK_PATH")
    fi
  fi
  for icon_ext in png svg xpm ico; do
    if [[ -e "${USER_ICON_STEM}.${icon_ext}" ]]; then
      NAME_CONFLICTS+=("User icon exists: ${USER_ICON_STEM}.${icon_ext}")
    fi
  done
}

validate_app_name() {
  local candidate="$1"
  [[ -n "$candidate" ]] || return 1
  [[ "$candidate" != */* ]] || return 1
  [[ "$candidate" != "." && "$candidate" != ".." ]] || return 1
}

is_http_archive_url() {
  [[ "$1" =~ ^https?:// ]]
}

download_archive_if_url() {
  local input="$1"
  local suffix=".tar"
  local no_fragment
  local no_query
  local input_lc

  if ! is_http_archive_url "$input"; then
    return
  fi

  if ! command -v curl >/dev/null 2>&1; then
    error_line "curl is required to download URL archives."
    exit 1
  fi

  no_fragment="${input%%#*}"
  no_query="${no_fragment%%\?*}"
  input_lc="${no_query,,}"

  case "$input_lc" in
    *.tar.gz|*.tgz) suffix=".tar.gz" ;;
    *.tar.bz2|*.tbz2) suffix=".tar.bz2" ;;
    *.tar.xz|*.txz) suffix=".tar.xz" ;;
    *.tar.zst|*.tzst) suffix=".tar.zst" ;;
    *.pkg.tar.zst) suffix=".pkg.tar.zst" ;;
    *.tar) suffix=".tar" ;;
    *.zip) suffix=".zip" ;;
    *.deb) suffix=".deb" ;;
    *.rpm) suffix=".rpm" ;;
  esac

  DOWNLOADED_ARCHIVE="$(mktemp "/tmp/judo-download.XXXXXX${suffix}")"
  info_line "Downloading archive from URL: $input"
  curl -fL "$input" -o "$DOWNLOADED_ARCHIVE"
  ARCHIVE="$DOWNLOADED_ARCHIVE"
  success_line "Downloaded archive: $ARCHIVE"
}

extract_deb_payload() {
  local deb_path="$1"
  local data_archive=""

  if ! command -v ar >/dev/null 2>&1; then
    error_line "ar is required to extract .deb files."
    exit 1
  fi

  DEB_WORK_DIR="$(mktemp -d "/tmp/judo-deb.XXXXXX")"
  (
    cd "$DEB_WORK_DIR"
    ar x "$deb_path"
  )

  data_archive="$(find "$DEB_WORK_DIR" -maxdepth 1 -type f -name 'data.tar*' | head -1 || true)"
  if [[ -z "$data_archive" ]]; then
    error_line "Unsupported .deb: payload archive data.tar.* not found"
    exit 1
  fi

  info_line "Extracting Debian payload: $(basename "$data_archive")"
  tar -xf "$data_archive" -C "$TEMP_DIR"
}

extract_zip_payload() {
  local zip_path="$1"

  if command -v unzip >/dev/null 2>&1; then
    unzip -q "$zip_path" -d "$TEMP_DIR"
    return
  fi
  if command -v bsdtar >/dev/null 2>&1; then
    bsdtar -xf "$zip_path" -C "$TEMP_DIR"
    return
  fi

    error_line "zip extraction requires unzip or bsdtar."
  exit 1
}

extract_tar_zst_payload() {
  local archive_path="$1"

  if tar --zstd -xf "$archive_path" -C "$TEMP_DIR" 2>/dev/null; then
    return
  fi
  if command -v zstd >/dev/null 2>&1 && tar -I zstd -xf "$archive_path" -C "$TEMP_DIR" 2>/dev/null; then
    return
  fi

    error_line "Could not extract zstd tar archive; requires tar with zstd support (or zstd)."
  exit 1
}

extract_rpm_payload() {
  local rpm_path="$1"

  if command -v bsdtar >/dev/null 2>&1; then
    if bsdtar -xf "$rpm_path" -C "$TEMP_DIR"; then
      return
    fi
  fi

  if command -v rpm2cpio >/dev/null 2>&1 && command -v cpio >/dev/null 2>&1; then
    (
      cd "$TEMP_DIR"
      rpm2cpio "$rpm_path" | cpio -idm --quiet
    )
    return
  fi

    error_line "rpm extraction requires bsdtar or rpm2cpio+cpio."
  exit 1
}

extract_archive() {
  local archive_path="$1"
  local archive_lc="${archive_path,,}"

  case "$archive_lc" in
    *.tar.gz|*.tgz) tar -xzf "$archive_path" -C "$TEMP_DIR" ;;
    *.tar.bz2|*.tbz2) tar -xjf "$archive_path" -C "$TEMP_DIR" ;;
    *.tar.xz|*.txz) tar -xJf "$archive_path" -C "$TEMP_DIR" ;;
    *.pkg.tar.zst|*.tar.zst|*.tzst) extract_tar_zst_payload "$archive_path" ;;
    *.tar) tar -xf "$archive_path" -C "$TEMP_DIR" ;;
    *.zip) extract_zip_payload "$archive_path" ;;
    *.deb) extract_deb_payload "$archive_path" ;;
    *.rpm) extract_rpm_payload "$archive_path" ;;
    *) error_line "Unsupported format"; exit 1 ;;
  esac
}

describe_archive_file_type() {
  local path="$1"

  if ! command -v file >/dev/null 2>&1; then
    info_line "unknown (file command not available)"
    return
  fi

  file -b "$path"
}

archive_file_type_matches() {
  local archive_path="$1"
  local file_type="$2"
  local archive_lc="${archive_path,,}"

  [[ "$file_type" == "unknown (file command not available)" ]] && return 0

  case "$archive_lc" in
    *.tar.gz|*.tgz) [[ "$file_type" == *"gzip compressed data"* ]] ;;
    *.tar.bz2|*.tbz2) [[ "$file_type" == *"bzip2 compressed data"* ]] ;;
    *.tar.xz|*.txz) [[ "$file_type" == *"XZ compressed data"* ]] ;;
    *.tar.zst|*.tzst|*.pkg.tar.zst) [[ "$file_type" == *"Zstandard compressed data"* ]] ;;
    *.tar) [[ "$file_type" == *"tar archive"* ]] ;;
    *.zip) [[ "$file_type" == *"Zip archive data"* ]] ;;
    *.deb) [[ "$file_type" == *"Debian binary package"* ]] ;;
    *.rpm) [[ "$file_type" == *"RPM"* ]] ;;
    *) return 0 ;;
  esac
}

preflight_archive_type() {
  local archive_path="$1"
  local archive_lc="${archive_path,,}"
  local file_type

  file_type="$(describe_archive_file_type "$archive_path")"
  info_line "Archive file type: $file_type"

  if ! archive_file_type_matches "$archive_path" "$file_type"; then
    warn_line "Archive suffix does not match the detected file type."
    warn_line "Use the actual archive type shown above, or rename/correct the file."
    return 1
  fi
}

looks_like_windows_bundle() {
  local root="$1"
  local windows_hits=0
  local non_windows_hits=0
  local f
  local base_lc

  while IFS= read -r -d '' f; do
    base_lc="$(basename "$f")"
    base_lc="${base_lc,,}"
    case "$base_lc" in
      *.exe|*.dll|*.pdb|*.msi|*.bat|*.cmd|*.sys|*.ocx)
        windows_hits=$((windows_hits + 1))
        ;;
      *.appimage|*.desktop|*.sh|*.bin|*.run)
        non_windows_hits=$((non_windows_hits + 1))
        ;;
    esac
  done < <(find "$root" -type f \( -name "*.exe" -o -name "*.dll" -o -name "*.pdb" -o -name "*.msi" -o -name "*.bat" -o -name "*.cmd" -o -name "*.sys" -o -name "*.ocx" -o -name "*.appimage" -o -name "*.desktop" -o -name "*.sh" -o -name "*.bin" -o -name "*.run" \) -print0 2>/dev/null)

  (( windows_hits > 0 && non_windows_hits == 0 ))
}

score_executable() {
  local exec_path="$1"
  local filename
  local filename_lc
  local app_lc
  local score=0

  filename="$(basename "$exec_path")"
  filename_lc="${filename,,}"
  app_lc="${APP_NAME,,}"

  [[ "$filename_lc" == "$app_lc" ]] && score=$((score + 220))
  [[ "$filename_lc" == "${app_lc}."* ]] && score=$((score + 90))
  [[ "$filename_lc" == "${app_lc}-"* || "$filename_lc" == "${app_lc}_"* ]] && score=$((score + 70))
  [[ "$filename_lc" == *"$app_lc"* ]] && score=$((score + 40))

  [[ "$exec_path" != *"/."* ]] && score=$((score + 10))
  [[ "$exec_path" == */bin/* ]] && score=$((score + 15))
  [[ "$exec_path" == */app/* ]] && score=$((score + 15))
  [[ "$exec_path" == */lib/* ]] && score=$((score - 25))

  [[ "$filename_lc" == *"test"* ]] && score=$((score - 30))
  [[ "$filename_lc" == *"debug"* ]] && score=$((score - 30))
  [[ "$filename_lc" == *"helper"* ]] && score=$((score - 30))
  [[ "$filename_lc" == *"daemon"* ]] && score=$((score - 30))

  # Avoid launcher/wrapper helpers when a real app binary is present.
  [[ "$filename_lc" == *.sh ]] && score=$((score - 80))
  [[ "$filename_lc" == *"wrapper"* ]] && score=$((score - 80))
  [[ "$filename_lc" == *"launcher"* ]] && score=$((score - 50))
  [[ "$filename_lc" == *"exec-outside"* ]] && score=$((score - 250))
  [[ "$filename_lc" == *"outside"*"env"* ]] && score=$((score - 200))

  printf '%s\n' "$score"
}

is_executable_candidate() {
  local exec_path="$1"
  local filename_lc

  filename_lc="$(basename "$exec_path")"
  filename_lc="${filename_lc,,}"

  # .desktop files can have the executable bit, but they are launcher metadata.
  [[ "$filename_lc" != *.desktop ]]
}

pick_best_executable() {
  local root="$1"
  local best_score=-999999
  local best_exec=""
  local score=0

  while IFS= read -r -d '' exec; do
    is_executable_candidate "$exec" || continue
    score="$(score_executable "$exec")"
    if (( score > best_score )); then
      best_score="$score"
      best_exec="$exec"
    fi
  done < <(find "$root" -type f -executable -print0)

  printf '%s' "$best_exec"
}

determine_stage_source() {
  local executable_path="$1"
  local rel_path
  local top_dir
  local top_entries=()

  shopt -s nullglob dotglob
  top_entries=("$TEMP_DIR"/*)
  shopt -u nullglob dotglob

  if (( ${#top_entries[@]} == 1 )) && [[ -d "${top_entries[0]}" ]]; then
    STAGE_SOURCE="${top_entries[0]}"
    info_line "Detected single top-level directory; staging from: $STAGE_SOURCE"
    return
  fi

  rel_path="${executable_path#"$TEMP_DIR"/}"
  top_dir="${rel_path%%/*}"
  if [[ "$rel_path" != "$executable_path" && -n "$top_dir" && -d "$TEMP_DIR/$top_dir" ]]; then
    STAGE_SOURCE="$TEMP_DIR/$top_dir"
    info_line "Detected grouped layout; staging from: $STAGE_SOURCE"
    return
  fi

  STAGE_SOURCE="$TEMP_DIR"
  info_line "Staging from extracted root."
}

resolve_name_conflicts() {
  while true; do
    find_name_conflicts
    if (( ${#NAME_CONFLICTS[@]} == 0 )); then
      return
    fi

    if (( FORCE == 1 )); then
      success_line "Force enabled; proceeding despite name conflicts:"
      printf '  - %s\n' "${NAME_CONFLICTS[@]}"
      return
    fi

    if [[ ! -t 0 ]]; then
      warn_line "Name conflicts detected for '$APP_NAME':"
      printf '  - %s\n' "${NAME_CONFLICTS[@]}"
      warn_line "Re-run with --force to replace these targets, or choose a different AppName."
      exit 1
    fi

    warn_line "Name conflicts detected for '$APP_NAME':"
      printf '  - %s\n' "${NAME_CONFLICTS[@]}"
    status_line "Overwrite existing targets? [y]es, [n]ew name, [c]ancel"

    while true; do
      read -r -p "> " choice
      case "${choice,,}" in
        y|yes|f|force)
          FORCE=1
          success_line "Proceeding with overwrite for '$APP_NAME'."
          return
          ;;
        n|new)
          while true; do
            read -r -p "Enter new AppName: " new_name
            if ! validate_app_name "$new_name"; then
              warn_line "Invalid name. Use a non-empty name without '/'."
              continue
            fi
            APP_NAME="$new_name"
            refresh_name_paths
            break
          done
          break
          ;;
        c|cancel)
          error_line "Cancelled."
          exit 1
          ;;
        *)
          warn_line "Please type n, f, or c."
          ;;
      esac
    done
  done
}

pick_best_desktop_file() {
  # Picks the best vendor desktop file from within a tree, printing its full path or nothing.
  local root="$1"
  local app_lc="${APP_NAME,,}"
  local best_score=-999999
  local best_file=""

  while IFS= read -r -d '' f; do
    local score=0
    local base
    base="$(basename "$f")"
    local base_lc="${base,,}"

    # Filename matches
    [[ "$base_lc" == "${app_lc}.desktop" ]] && score=$((score + 200))
    [[ "$base_lc" == *"$app_lc"* ]] && score=$((score + 80))

    # Prefer canonical locations
    [[ "$f" == */share/applications/* ]] && score=$((score + 60))
    [[ "$f" == */applications/* ]] && score=$((score + 30))

    # Name matches
    local name
    name="$(grep -m1 '^Name=' "$f" 2>/dev/null | cut -d= -f2- || true)"
    local name_lc="${name,,}"
    [[ -n "$name_lc" && "$name_lc" == "$app_lc" ]] && score=$((score + 140))
    [[ -n "$name_lc" && "$name_lc" == *"$app_lc"* ]] && score=$((score + 70))

    # Exec hints
    local ex
    ex="$(grep -m1 '^Exec=' "$f" 2>/dev/null | cut -d= -f2- || true)"
    local ex_lc="${ex,,}"
    [[ -n "$ex_lc" && "$ex_lc" == *"$app_lc"* ]] && score=$((score + 40))

    # Basic sanity: must have a Desktop Entry header somewhere
    if ! grep -q '^\[Desktop Entry\]' "$f" 2>/dev/null; then
      score=$((score - 200))
    fi

    if (( score > best_score )); then
      best_score="$score"
      best_file="$f"
    fi
  done < <(find "$root" -type f -name "*.desktop" -print0 2>/dev/null)

  # Require a minimally positive score to avoid random .desktop matches
  if [[ -n "$best_file" && "$best_score" -ge 50 ]]; then
    printf '%s\n' "$best_file"
  fi
}

score_icon_candidate() {
  local icon_path="$1"
  local filename
  local filename_lc
  local app_lc
  local score=0

  filename="$(basename "$icon_path")"
  filename_lc="${filename,,}"
  app_lc="${APP_NAME,,}"

  # Strong filename hints.
  [[ "$filename_lc" == "$app_lc".* ]] && score=$((score + 180))
  [[ "$filename_lc" == "${app_lc}"-* || "$filename_lc" == "${app_lc}"_* ]] && score=$((score + 150))
  [[ "$filename_lc" == *"$app_lc"* ]] && score=$((score + 120))
  [[ "$filename_lc" == *"logo"* ]] && score=$((score + 140))
  [[ "$filename_lc" == *"icon"* ]] && score=$((score + 120))

  # Prefer canonical icon-ish locations.
  [[ "$icon_path" == */share/icons/* ]] && score=$((score + 70))
  [[ "$icon_path" == */icons/* ]] && score=$((score + 50))
  [[ "$icon_path" == */pixmaps/* ]] && score=$((score + 40))
  [[ "$icon_path" == */hicolor/* ]] && score=$((score + 30))
  [[ "$icon_path" == */icon/* ]] && score=$((score + 20))

  # Prefer files near the top of the source tree.
  [[ "$icon_path" != *"/."* ]] && score=$((score + 10))
  [[ "$icon_path" == */./* ]] && score=$((score - 20))

  # Penalize obvious non-icons and test assets.
  [[ "$icon_path" == */test/* || "$icon_path" == */tests/* || "$icon_path" == */testdata/* ]] && score=$((score - 180))
  [[ "$icon_path" == */example/* || "$icon_path" == */examples/* || "$icon_path" == */demo/* || "$icon_path" == */samples/* || "$icon_path" == */sample/* ]] && score=$((score - 120))
  [[ "$icon_path" == */doc/* || "$icon_path" == */docs/* ]] && score=$((score - 100))
  [[ "$icon_path" == */screenshot/* || "$icon_path" == */screenshots/* ]] && score=$((score - 150))
  [[ "$filename_lc" == *"screenshot"* ]] && score=$((score - 150))
  [[ "$filename_lc" == *"thumb"* ]] && score=$((score - 120))
  [[ "$filename_lc" == *"small"* ]] && score=$((score - 80))
  [[ "$filename_lc" == *"16x16"* || "$filename_lc" == *"24x24"* || "$filename_lc" == *"32x32"* || "$filename_lc" == *"48x48"* ]] && score=$((score - 100))

  printf '%s\n' "$score"
}

list_icon_file_candidates() {
  local root="$1"
  local icon
  local score

  while IFS= read -r -d '' icon; do
    score="$(score_icon_candidate "$icon")"
    printf '%s\t%s\t%s\n' "$score" "$icon" "$icon"
  done < <(find "$root" -type f \( -iname "*.png" -o -iname "*.svg" -o -iname "*.xpm" \) -print0 2>/dev/null | sort -z)
}

desktop_icon_candidate() {
  local desktop_file="$1"
  local icon_line
  local icon_name
  local resolved_path

  if [[ -z "$desktop_file" || ! -f "$desktop_file" ]]; then
    return 1
  fi

  icon_line="$(grep -m1 '^Icon=' "$desktop_file" 2>/dev/null || true)"
  if [[ -z "$icon_line" ]]; then
    return 1
  fi

  icon_name="${icon_line#Icon=}"
  resolved_path="$(resolve_icon_name_path "$icon_name" || true)"
  if [[ -z "$resolved_path" ]]; then
    return 1
  fi

  printf '%s\t%s\t%s\n' "500" "$icon_name" "Icon=$icon_name (from desktop file, resolves to $resolved_path)"
}

score_desktop_candidate() {
  local f="$1"
  local app_lc="${APP_NAME,,}"
  local score=0
  local base
  local base_lc

  base="$(basename "$f")"
  base_lc="${base,,}"

  [[ "$base_lc" == "${app_lc}.desktop" ]] && score=$((score + 200))
  [[ "$base_lc" == *"$app_lc"* ]] && score=$((score + 80))
  [[ "$f" == */share/applications/* ]] && score=$((score + 60))
  [[ "$f" == */applications/* ]] && score=$((score + 30))

  local name
  name="$(grep -m1 '^Name=' "$f" 2>/dev/null | cut -d= -f2- || true)"
  local name_lc="${name,,}"
  [[ -n "$name_lc" && "$name_lc" == "$app_lc" ]] && score=$((score + 140))
  [[ -n "$name_lc" && "$name_lc" == *"$app_lc"* ]] && score=$((score + 70))

  local ex
  ex="$(grep -m1 '^Exec=' "$f" 2>/dev/null | cut -d= -f2- || true)"
  local ex_lc="${ex,,}"
  [[ -n "$ex_lc" && "$ex_lc" == *"$app_lc"* ]] && score=$((score + 40))

  local icon_line
  icon_line="$(grep -m1 '^Icon=' "$f" 2>/dev/null || true)"
  if [[ -n "$icon_line" ]]; then
    local icon_name="${icon_line#Icon=}"
    if resolve_icon_name "$icon_name"; then
      score=$((score + 90))
    else
      score=$((score - 60))
    fi
  fi

  if ! grep -q '^\[Desktop Entry\]' "$f" 2>/dev/null; then
    score=$((score - 200))
  fi

  printf '%s\n' "$score"
}

resolve_icon_name_path() {
  local icon_name="$1"
  local search_dir
  local ext
  local resolved_path

  if [[ -z "$icon_name" ]]; then
    return 1
  fi

  if [[ "$icon_name" == /* && -f "$icon_name" ]]; then
    printf '%s\n' "$icon_name"
    return 0
  fi

  for search_dir in \
    "$USER_HOME/.local/share/icons" \
    "/usr/local/share/icons" \
    "/usr/share/icons" \
    "/usr/share/pixmaps"
  do
    [[ -d "$search_dir" ]] || continue

    for ext in png svg xpm ico; do
      resolved_path="$(find "$search_dir" -type f \( -iname "${icon_name}.${ext}" -o -iname "${icon_name}" \) -print -quit 2>/dev/null || true)"
      if [[ -n "$resolved_path" ]]; then
        printf '%s\n' "$resolved_path"
        return 0
      fi
    done
  done

  return 1
}

resolve_icon_name() {
  resolve_icon_name_path "$1" >/dev/null
}

list_executable_candidates() {
  local root="$1"
  local exec
  local score

  while IFS= read -r -d '' exec; do
    is_executable_candidate "$exec" || continue
    score="$(score_executable "$exec")"
    printf '%s\t%s\t%s\n' "$score" "$exec" "$exec"
  done < <(find "$root" -type f -executable -print0 2>/dev/null | sort -z)
}

list_desktop_candidates() {
  local root="$1"
  local f
  local score

  while IFS= read -r -d '' f; do
    score="$(score_desktop_candidate "$f")"
    printf '%s\t%s\t%s\n' "$score" "$f" "$f"
  done < <(find "$root" -type f -name "*.desktop" -print0 2>/dev/null | sort -z)
}

collect_top_candidates() {
  local max_candidates="$1"
  local root="$2"
  local kind="$3"
  local -n out="$4"
  local selected_desktop="${5:-}"
  local line

  out=()

  case "$kind" in
    exec)
      while IFS= read -r line; do
        out+=("$line")
      done < <(list_executable_candidates "$root" | sort -t $'\t' -k1,1nr)
      ;;
    desktop)
      while IFS= read -r line; do
        out+=("$line")
      done < <(list_desktop_candidates "$root" | sort -t $'\t' -k1,1nr)
      ;;
    icon)
      if [[ -n "$selected_desktop" ]]; then
        local desktop_icon_candidate_line=""
        desktop_icon_candidate_line="$(desktop_icon_candidate "$selected_desktop" || true)"
        if [[ -n "$desktop_icon_candidate_line" ]]; then
          out+=("$desktop_icon_candidate_line")
        fi
      fi
      while IFS= read -r line; do
        out+=("$line")
      done < <(list_icon_file_candidates "$root" | sort -t $'\t' -k1,1nr)
      ;;
    *)
      error_line "Unknown candidate kind: $kind"
      exit 1
      ;;
  esac

  if (( ${#out[@]} > max_candidates )); then
    out=("${out[@]:0:max_candidates}")
  fi
}

candidate_value_exists() {
  local needle="$1"
  local -n candidates="$2"
  local line
  local score
  local value
  local label

  for line in "${candidates[@]}"; do
    IFS=$'\t' read -r score value label <<< "$line"
    if [[ "$value" == "$needle" ]]; then
      return 0
    fi
  done

  return 1
}

print_candidate_block() {
  local title="$1"
  local -n candidates="$2"
  local selected_path="${3:-}"
  local kind="${4:-generic}"
  local i
  local score
  local path
  local marker=""
  local extra=""

  printf '%b%s%b\n' "${C_BOLD}${C_MAGENTA}" "$title:" "$C_RESET" >&2
  if (( ${#candidates[@]} == 0 )); then
    printf '%b%s%b\n' "$C_DIM" "  <none>" "$C_RESET" >&2
    return
  fi

  for i in "${!candidates[@]}"; do
    IFS=$'\t' read -r score value label <<< "${candidates[$i]}"
    [[ -z "${label:-}" ]] && label="$value"
    marker=""
    if [[ -n "$selected_path" && "$value" == "$selected_path" ]]; then
      marker="* "
    fi
    if [[ -n "$marker" ]]; then
      printf '  %b%d)%b %s%b[%s]%b %s%b\n' "${C_GREEN}${C_BOLD}" "$((i + 1))" "$C_RESET" "$marker" "${C_GREEN}${C_BOLD}" "$score" "$C_RESET" "$label" "" >&2
    else
      printf '  %d) [%s] %s\n' "$((i + 1))" "$score" "$label" >&2
    fi
  done
}

prompt_candidate_selection() {
  local kind_label="$1"
  local allow_skip="$2"
  local current="$3"
  local -n candidates="$4"
  local choice=""
  local score
  local value
  local label
  local max_index="${#candidates[@]}"

  while true; do
    if (( max_index > 0 )); then
      if (( allow_skip == 1 )); then
        echo "Choose $kind_label [1-$max_index, absolute path, enter to keep current, s to skip]:" >&2
      else
        echo "Choose $kind_label [1-$max_index, absolute path, enter to keep current]:" >&2
      fi
    else
      if (( allow_skip == 1 )); then
        echo "Choose $kind_label [absolute path, enter to keep current, s to skip]:" >&2
      else
        echo "Choose $kind_label [absolute path, enter to keep current]:" >&2
      fi
    fi
    read -r -p "> " choice
    case "${choice,,}" in
      "")
        printf '%s' "$current"
        return
        ;;
      s|skip|none)
        if (( allow_skip == 1 )); then
          printf '%s' ""
          return
        fi
        warn_line "Skipping is not allowed for $kind_label." >&2
        ;;
      *[!0-9]*)
        if [[ "$choice" == /* && -e "$choice" ]]; then
          case "$kind_label" in
            executable)
              if [[ -x "$choice" && -f "$choice" ]]; then
                printf '%s' "$choice"
                return
              fi
              warn_line "That path is not an executable file."
              ;;
            "desktop file")
              if [[ -f "$choice" ]]; then
                printf '%s' "$choice"
                return
              fi
              warn_line "That path is not a desktop file."
              ;;
            icon)
              if [[ -f "$choice" ]]; then
                printf '%s' "$choice"
                return
              fi
              warn_line "That path is not an icon file."
              ;;
            *)
              error_line "Unsupported selection kind."
              return 1
              ;;
          esac
          continue
        fi
        warn_line "Please enter a number or an absolute path."
        ;;
      *)
        if (( max_index > 0 )) && (( choice >= 1 && choice <= max_index )); then
          IFS=$'\t' read -r score value label <<< "${candidates[$((choice - 1))]}"
          printf '%s' "$value"
          return
        fi
        if (( max_index > 0 )); then
          warn_line "Please choose a number from 1 to $max_index."
        else
          warn_line "Please enter an absolute path, or press enter to keep the current value."
        fi
        ;;
    esac
  done
}

review_install_choices() {
  local -n exec_candidates="$1"
  local -n desktop_candidates="$2"
  local work_root="$3"
  local -n selected_exec="$4"
  local -n selected_desktop="$5"
  local -n selected_icon="$6"
  local icon_candidates=()
  local selection

  while true; do
    collect_top_candidates 10 "$work_root" icon icon_candidates "$selected_desktop"
    if [[ -n "$selected_icon" ]]; then
      if [[ "$selected_icon" == /* && -e "$selected_icon" ]]; then
        : # keep absolute-path overrides as-is
      elif ! candidate_value_exists "$selected_icon" icon_candidates; then
        selected_icon=""
      fi
    fi
    if [[ -z "$selected_icon" && ${#icon_candidates[@]} > 0 ]]; then
      IFS=$'\t' read -r _ selected_icon _ <<< "${icon_candidates[0]}"
    fi

    print_candidate_block "Desktop file candidates" desktop_candidates "$selected_desktop" "desktop"
    print_candidate_block "Executable candidates" exec_candidates "$selected_exec" "exec"
    print_candidate_block "Icon candidates" icon_candidates "$selected_icon" "icon"
    printf '%b%s%b\n' "${C_BOLD}${C_CYAN}" "Selected defaults:" "$C_RESET" >&2
    printf '  Desktop file: %b%s%b\n' "$C_GREEN" "${selected_desktop:-<generate>}" "$C_RESET" >&2
    printf '  Executable: %b%s%b\n' "$C_GREEN" "${selected_exec:-<none>}" "$C_RESET" >&2
    printf '  Icon: %b%s%b\n' "$C_GREEN" "${selected_icon:-<none>}" "$C_RESET" >&2

    if [[ ! -t 0 ]]; then
      return
    fi

    status_line "Proceed with these choices? [c]onfirm, [e]dit, [x]cancel" >&2
    read -r -p "$(prompt_text '> ')" selection
    case "${selection,,}" in
      c|confirm|y|yes|"")
        return
        ;;
      x|cancel|n|no)
        echo "Cancelled."
        exit 1
      ;;
      e|edit)
        selected_desktop="$(prompt_candidate_selection "desktop file" 1 "$selected_desktop" desktop_candidates)"
        selected_exec="$(prompt_candidate_selection "executable" 0 "$selected_exec" exec_candidates)"
        selected_icon="$(prompt_candidate_selection "icon" 1 "$selected_icon" icon_candidates)"
        ;;
      *)
        warn_line "Please type c, e, or x."
        ;;
    esac
  done
}

write_desktop_from_vendor() {
  # Writes a desktop file based on vendor file, but overwrites the keys judo manages.
  local vendor="$1"
  local out="$2"
  local name="$3"
  local exec_line="$4"      # full Exec value (no "Exec=" prefix)
  local icon_entry="$5"     # full "Icon=..." line
  local categories="$6"

  # If vendor doesn't contain [Desktop Entry], fail so caller can fallback.
  if ! grep -q '^\[Desktop Entry\]' "$vendor" 2>/dev/null; then
    return 1
  fi

  awk -v name="$name" \
      -v exec_line="$exec_line" \
      -v icon_entry="$icon_entry" \
      -v categories="$categories" '
    BEGIN { in_de=0; injected=0 }
    /^\[Desktop Entry\]$/ {
      print
      print "Version=1.0"
      print "Name=" name
      print "Exec=" exec_line
      print icon_entry
      print "Terminal=false"
      print "Type=Application"
      print "Categories=" categories
      in_de=1
      injected=1
      next
    }
    {
      if (in_de==1) {
        if ($0 ~ /^\[/) { in_de=0 }  # leaving group
        else if ($0 ~ /^(Version|Name|Exec|Icon|Terminal|Type|Categories)=/) { next }
      }
      print
    }
    END {
      if (injected==0) { exit 2 }
    }
 ' "$vendor" > "$out"
}

